APP_URL="MY_APP_URL"
NEXT_PUBLIC_APP_URL="MY_APP_URL"

BETTER_AUTH_SECRET="my_secret_key"

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

CRON_SECRET=your_super_secret_password_here

# SMTP (used for notification emails only, not for auth)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@your-tldsync-domain.com
SMTP_PASSWORD=your-secure-app-password
SMTP_FROM=noreply@your-tldsync-domain.com

# Discord webhook for notifications
DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# ── OAuth ─────────────────────────────────────────────────────
# Google: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: {APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL: {APP_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
